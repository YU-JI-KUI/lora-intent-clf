# =============================================================================
# machine.env — 机器特定配置（每台机器独立维护）
#
# 使用方式：
#   cp machine.env.example machine.env
#   vim machine.env         # 至少修改 MODEL_PATH 和 NPROC_PER_NODE
#
# 注意：machine.env 已加入 .gitignore，不会提交到仓库。
#       machine.env.example 是模板，提交到仓库供新机器参考。
#
# 生效范围：
#   所有 scripts/*.sh 脚本均自动加载本文件。
#   Python 脚本通过 src/config.py 的 load_project_config() 读取本文件。
#
# 参数分类：
#   [必须]  每台机器不同，必须修改
#   [路径]  可选，不填时由 PROJECT_ROOT 自动派生
#   [LoRA]  LoRA 结构超参，调参实验时修改
#   [训练]  训练超参，调参实验时修改
#   [早停]  early stopping 配置
# =============================================================================

# ─── [必须] 机器相关 ──────────────────────────────────────────────────────────

# 基座模型路径（每台机器通常不同）
MODEL_PATH=/workspace/Qwen3-8B

# GPU 数量（V100×6 填 6，V100×8 填 8）
NPROC_PER_NODE=8

# ─── [路径] 可选（不填则使用 PROJECT_ROOT 派生的默认值）─────────────────────
# PROJECT_ROOT 由脚本自动从文件路径推导，无需手动设置。

# 训练输出目录（LoRA adapter 保存位置，同时也是 adapter_name_or_path）
# 默认: <PROJECT_ROOT>/saves/qwen3-8b/lora/sft
# OUTPUT_DIR=/workspace/lora-intent-clf/saves/qwen3-8b/lora/sft

# 数据集目录（包含 dataset_info.json 和所有数据文件）
# 默认: <PROJECT_ROOT>/data
# DATASET_DIR=/workspace/lora-intent-clf/data

# DeepSpeed 配置文件路径
#
# ⚠️ V100 16GB 必须使用 offload 版本（默认），否则 optimizer state 会 OOM：
#   ZeRO-3 将 8B 模型分片后，每张 V100 仍持有 ~14GB optimizer state（fp32 主权重 +
#   Adam m/v），超出 16GB 显存。offload 版本将 optimizer state 卸载到 CPU RAM，
#   GPU 仅保留 ~2GB 参数分片，彻底解决 OOM。
#
# 可选值:
#   ds_z3_offload_config.json  — V100 16GB / 显存紧张（默认，推荐）
#   ds_z3_config.json          — A100 40GB+ / 显存充足（速度更快）
# 默认: <PROJECT_ROOT>/configs/deepspeed/ds_z3_offload_config.json
# DEEPSPEED_CONFIG=/workspace/lora-intent-clf/configs/deepspeed/ds_z3_offload_config.json

# 模型导出目录（LoRA adapter 合并进基座模型后的保存位置）
# 默认: <PROJECT_ROOT>/models/qwen3-8b-intent-clf
# EXPORT_DIR=/workspace/lora-intent-clf/models/qwen3-8b-intent-clf

# ─── [LoRA] 结构超参 ─────────────────────────────────────────────────────────
# 以下参数决定 LoRA adapter 的结构，影响参数量和表达能力。
# 修改后需重新训练，不能热更新。

# LoRA 秩：决定可训练参数量。简单二分类任务推荐 8，复杂任务可用 16/32。
# 可选值: 4, 8, 16, 32, 64
LORA_RANK=8

# LoRA 缩放因子：通常设为 LORA_RANK 的 2 倍，实际缩放比 = LORA_ALPHA / LORA_RANK
# 可选值: 与 LORA_RANK 同步调整，如 rank=8→alpha=16, rank=16→alpha=32
LORA_ALPHA=16

# LoRA Dropout：防止过拟合。训练数据较少时可适当增大。
# 可选值: 0.0（无 dropout）, 0.05, 0.1, 0.2
LORA_DROPOUT=0.1

# LoRA 目标模块：插入 LoRA adapter 的模块范围
# 可选值:
#   all              — 所有线性层（效果最好，默认）
#   q_proj,v_proj    — 仅 QV 注意力（参数最少）
#   q_proj,k_proj,v_proj,o_proj — 所有注意力投影
LORA_TARGET=all

# ─── [训练] 超参数 ────────────────────────────────────────────────────────────

# 最大序列长度：意图识别文本通常较短，256 覆盖绝大多数场景且节省显存
# 可选值: 128, 256, 512, 1024
CUTOFF_LEN=256

# 每张 GPU 的训练 batch size（V100 16GB 显存限制，建议不超过 4）
# 可选值: 1, 2, 4
PER_DEVICE_TRAIN_BATCH_SIZE=2

# 梯度累积步数：有效批次 = NPROC_PER_NODE × PER_DEVICE_TRAIN_BATCH_SIZE × 此值
# 8卡×2×4=64（推荐），6卡×2×4=48，调整此值可在不同卡数下保持相同有效批次
# 可选值: 2, 4, 8, 16
GRADIENT_ACCUMULATION_STEPS=4

# 初始学习率：LoRA 分类任务推荐 1e-4 ~ 3e-4
# 可选值: 5e-5, 1e-4, 2e-4, 5e-4
LEARNING_RATE=2e-4

# 最大训练轮数：配合早停使用，训练轮数可以设置大一些
# 可选值: 5, 10, 20
NUM_TRAIN_EPOCHS=10

# 预热比例：学习率从 0 线性上升到初始值的训练步数占比
# 可选值: 0.0, 0.03, 0.05, 0.1
WARMUP_RATIO=0.05

# 权重衰减（L2 正则）
# 可选值: 0.0, 0.01, 0.1
WEIGHT_DECAY=0.01

# 梯度裁剪最大范数
# 可选值: 0.5, 1.0, 2.0
MAX_GRAD_NORM=1.0

# ─── [监控 & 保存] ───────────────────────────────────────────────────────────
# ⚠️ SAVE_STEPS 必须等于 EVAL_STEPS，早停依赖每次评估后的 checkpoint

# 日志打印间隔（训练步数）
LOGGING_STEPS=20

# 评估间隔（训练步数）：50K数据/8卡/bs2/grad_accum4 ≈ 781步/epoch，每200步≈4次/epoch
EVAL_STEPS=200

# 保存间隔（训练步数）：必须与 EVAL_STEPS 保持一致，否则早停无法加载最优模型
SAVE_STEPS=200

# ─── [早停] Early Stopping ────────────────────────────────────────────────────
# 早停监控 eval_loss，连续 PATIENCE 次评估无改善则停止训练并恢复最优 checkpoint。
# 同时作用于 LlamaFactory CLI 和 Python 训练路径。

# 连续多少次评估无改善后停止。patience=5 × eval_steps=200 ≈ 1000步≈1.3轮无改善
# 可选值: 3, 5, 10（越大越保守，越小越激进）
EARLY_STOPPING_PATIENCE=5

# 最小改善阈值：eval_loss 需下降超过此值才算"有改善"（相对值）
# 可选值: 0.0（任意改善）, 1e-4, 1e-3
EARLY_STOPPING_THRESHOLD=1e-4
